{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "bitcoin-indexer": {
      "type": "local",
      "command": ["uv", "run", "python", "-m", "app.mcp_server"],
      "environment": {
        "DB_HOST": "localhost",
        "DB_NAME": "blockchain-indexer",
        "DB_USER": "postgres",
        "DB_PASSWORD": "{env:DB_PASSWORD}",
        "PORT": "5432",
        "QUICKNODE_URL": "{env:QUICKNODE_URL}"
      },
      "enabled": true
    }
  }
}